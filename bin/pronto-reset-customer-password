#!/usr/bin/env bash
#
# Reset a customer password by email (dev/test only).
#
# Usage:
#   PRONTO_ENV=dev ./pronto-scripts/bin/pronto-reset-customer-password \
#     --email luartx@gmail.com \
#     --password 'ChangeMe!123'
#

set -euo pipefail

PRONTO_ENV="${PRONTO_ENV:-}"
if [[ -z "$PRONTO_ENV" ]]; then
  echo "ERROR: PRONTO_ENV no está definido. Usa dev|test." >&2
  exit 1
fi
if [[ "$PRONTO_ENV" != "dev" && "$PRONTO_ENV" != "test" ]]; then
  echo "ERROR: PRONTO_ENV=$PRONTO_ENV no permitido. Solo dev|test." >&2
  exit 1
fi

EMAIL=""
PASSWORD=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --email) EMAIL="${2:-}"; shift 2 ;;
    --password) PASSWORD="${2:-}"; shift 2 ;;
    *)
      echo "Argumento desconocido: $1" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$EMAIL" || -z "$PASSWORD" ]]; then
  echo "Uso: $0 --email <email> --password <password>" >&2
  exit 1
fi

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

PY_SCRIPT='
import os
import sys
from sqlalchemy import text
from pronto_shared.config import load_config
from pronto_shared.db import get_session, init_engine
from pronto_shared.security import hash_credentials, hash_identifier

email = (os.environ.get("_PRONTO_CUSTOMER_EMAIL", "") or "").strip().lower()
password = os.environ.get("_PRONTO_CUSTOMER_PASSWORD", "") or ""

if not email or not password:
    print("ERROR: email/password requeridos", file=sys.stderr)
    sys.exit(1)

config = load_config("pronto-api")
init_engine(config)

email_hash = hash_identifier(email)
password_hash = hash_credentials(email, password)

with get_session() as db:
    row = db.execute(
        text("SELECT id FROM pronto_customers WHERE lower(trim(email_normalized)) = :email LIMIT 1"),
        {"email": email},
    ).fetchone()
    if not row:
        print(f"ERROR: cliente no encontrado: {email}", file=sys.stderr)
        sys.exit(1)

    db.execute(
        text("""
            UPDATE pronto_customers
            SET password_hash = :password_hash,
                email_hash = :email_hash,
                updated_at = now()
            WHERE id = :customer_id
        """),
        {
            "password_hash": password_hash,
            "email_hash": email_hash,
            "customer_id": str(row[0]),
        },
    )
    db.commit()
    print(f"OK: password reseteado para {email}")
'

if docker compose -f "$REPO_ROOT/docker-compose.yml" ps --status running 2>/dev/null | grep -q "api"; then
  docker compose -f "$REPO_ROOT/docker-compose.yml" exec -T \
    -e "_PRONTO_CUSTOMER_EMAIL=$EMAIL" \
    -e "_PRONTO_CUSTOMER_PASSWORD=$PASSWORD" \
    api python3 -c "$PY_SCRIPT"
elif docker ps --format '{{.Names}}' | grep -q '^pronto-app-api-1$'; then
  docker exec \
    -e "_PRONTO_CUSTOMER_EMAIL=$EMAIL" \
    -e "_PRONTO_CUSTOMER_PASSWORD=$PASSWORD" \
    pronto-app-api-1 python3 -c "$PY_SCRIPT"
else
  echo "ERROR: No se encontró contenedor API activo (service=api o pronto-app-api-1)." >&2
  exit 1
fi
