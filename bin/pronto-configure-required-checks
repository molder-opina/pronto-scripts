#!/usr/bin/env bash
set -euo pipefail

SCRIPT_NAME="$(basename "$0")"

DEFAULT_CHECKS=("guardrails-static" "smoke-critical")
CHECKS=()
REPO_SLUG=""
BRANCH="main"
APPLY=0
BOOTSTRAP_IF_MISSING=1

usage() {
  cat <<EOF
Usage:
  ${SCRIPT_NAME} [--repo owner/repo] [--branch main] [--checks c1,c2] [--apply] [--no-bootstrap]

Description:
  Configura checks requeridos de branch protection para PRONTO:
  - guardrails-static
  - smoke-critical

Behavior:
  - Por defecto ejecuta dry-run (no cambia nada).
  - Con --apply aplica cambios usando gh api.
  - Si --repo no viene, intenta autodetectar desde git remote origin.
  - Si branch protection no existe y usas --apply, lo crea automáticamente.

Examples:
  ${SCRIPT_NAME}
  ${SCRIPT_NAME} --repo molder/pronto-api --branch develop
  ${SCRIPT_NAME} --repo molder/pronto-api --apply
  ${SCRIPT_NAME} --repo molder/pronto-api --checks guardrails-static,smoke-critical --apply
  ${SCRIPT_NAME} --repo molder/pronto-api --apply --no-bootstrap
EOF
}

fail() {
  echo "ERROR: $*" >&2
  exit 1
}

info() {
  echo "[INFO] $*"
}

ok() {
  echo "[OK] $*"
}

build_json_array() {
  local out="["
  local first=1
  local value
  for value in "$@"; do
    if [ "${first}" -eq 1 ]; then
      first=0
    else
      out+=", "
    fi
    out+="\"${value}\""
  done
  out+="]"
  echo "${out}"
}

detect_repo_from_remote() {
  local remote_url
  remote_url="$(git remote get-url origin 2>/dev/null || true)"
  if [ -z "${remote_url}" ]; then
    return 1
  fi

  # git@github.com:owner/repo.git
  if [[ "${remote_url}" =~ ^git@github\.com:([^/]+)/([^/]+)(\.git)?$ ]]; then
    echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]%.git}"
    return 0
  fi

  # https://github.com/owner/repo(.git)
  if [[ "${remote_url}" =~ ^https://github\.com/([^/]+)/([^/]+)(\.git)?$ ]]; then
    echo "${BASH_REMATCH[1]}/${BASH_REMATCH[2]%.git}"
    return 0
  fi

  return 1
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --repo)
      [ "$#" -ge 2 ] || fail "--repo requiere valor"
      REPO_SLUG="$2"
      shift 2
      ;;
    --branch)
      [ "$#" -ge 2 ] || fail "--branch requiere valor"
      BRANCH="$2"
      shift 2
      ;;
    --checks)
      [ "$#" -ge 2 ] || fail "--checks requiere valor csv"
      IFS=',' read -r -a CHECKS <<<"$2"
      shift 2
      ;;
    --apply)
      APPLY=1
      shift
      ;;
    --no-bootstrap)
      BOOTSTRAP_IF_MISSING=0
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "flag no reconocida: $1"
      ;;
  esac
done

if [ -z "${REPO_SLUG}" ]; then
  REPO_SLUG="$(detect_repo_from_remote || true)"
fi

[ -n "${REPO_SLUG}" ] || fail "No se pudo detectar repo. Usa --repo owner/repo."
[[ "${REPO_SLUG}" == */* ]] || fail "Repo inválido '${REPO_SLUG}'. Formato esperado: owner/repo"

if [ "${#CHECKS[@]}" -eq 0 ]; then
  CHECKS=("${DEFAULT_CHECKS[@]}")
fi

command -v gh >/dev/null 2>&1 || fail "gh CLI no está instalado"

info "Repo: ${REPO_SLUG}"
info "Branch: ${BRANCH}"
info "Required checks: ${CHECKS[*]}"

if [ "${APPLY}" -ne 1 ]; then
  info "DRY-RUN (sin cambios)."
  cat <<EOF

Para aplicar:
  ${SCRIPT_NAME} --repo ${REPO_SLUG} --branch ${BRANCH} --checks $(IFS=,; echo "${CHECKS[*]}") --apply
EOF
  exit 0
fi

gh auth status >/dev/null 2>&1 || fail "gh no autenticado. Ejecuta: gh auth login"

PROTECTION_ENDPOINT="repos/${REPO_SLUG}/branches/${BRANCH}/protection"
STATUS_ENDPOINT="${PROTECTION_ENDPOINT}/required_status_checks"

if ! gh api "${PROTECTION_ENDPOINT}" >/dev/null 2>&1; then
  if [ "${BOOTSTRAP_IF_MISSING}" -ne 1 ]; then
    fail "Branch protection no está habilitado para ${REPO_SLUG}:${BRANCH}. Habilítalo primero en GitHub."
  fi

  info "Branch protection no existe; creando protección base..."
  payload_file="$(mktemp)"
  checks_json="$(build_json_array "${CHECKS[@]}")"
  cat > "${payload_file}" <<EOF
{
  "required_status_checks": {
    "strict": true,
    "contexts": ${checks_json}
  },
  "enforce_admins": false,
  "required_pull_request_reviews": null,
  "restrictions": null,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "block_creations": false,
  "required_conversation_resolution": true,
  "lock_branch": false,
  "allow_fork_syncing": false
}
EOF
  if ! output="$(gh api --method PUT "${PROTECTION_ENDPOINT}" --input "${payload_file}" 2>&1)"; then
    rm -f "${payload_file}"
    if grep -q "Upgrade to GitHub Pro or make this repository public" <<<"${output}"; then
      fail "GitHub bloquea branch protection en ${REPO_SLUG}:${BRANCH} (plan/visibilidad). Solución: GitHub Pro/Team o repo público."
    fi
    fail "No se pudo crear branch protection base: ${output}"
  fi
  rm -f "${payload_file}"
  ok "Protección base creada para ${REPO_SLUG}:${BRANCH}"
fi

info "Activando strict status checks..."
checks_json="$(build_json_array "${CHECKS[@]}")"
strict_payload="$(mktemp)"
cat > "${strict_payload}" <<EOF
{
  "strict": true,
  "contexts": ${checks_json}
}
EOF
if ! output="$(gh api --method PATCH "${STATUS_ENDPOINT}" --input "${strict_payload}" 2>&1)"; then
  rm -f "${strict_payload}"
  if grep -q "Upgrade to GitHub Pro or make this repository public" <<<"${output}"; then
    fail "GitHub bloquea required checks en ${REPO_SLUG}:${BRANCH} (plan/visibilidad). Solución: GitHub Pro/Team o repo público."
  fi
  fail "No se pudo activar strict status checks: ${output}"
fi
rm -f "${strict_payload}"

info "Configurando contexts requeridos..."
cmd=(gh api --method PUT "${STATUS_ENDPOINT}/contexts")
for check_name in "${CHECKS[@]}"; do
  cmd+=(-f "contexts[]=${check_name}")
done
"${cmd[@]}" >/dev/null

CURRENT_CONTEXTS="$(gh api "${STATUS_ENDPOINT}/contexts" --jq '.[]' 2>/dev/null || true)"
for check_name in "${CHECKS[@]}"; do
  if ! grep -Fxq "${check_name}" <<<"${CURRENT_CONTEXTS}"; then
    fail "No se pudo verificar check requerido '${check_name}'"
  fi
done

ok "Checks requeridos configurados correctamente en ${REPO_SLUG}:${BRANCH}"
